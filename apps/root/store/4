#@ Check Palindrome

def is_palindrome(num):
    temp = num
    rev = 0

    while temp > 0:
        rem = temp % 10
        rev = rev * 10 + rem
        temp //= 10

    return num == rev


number = int(input("Enter a number: "))

if is_palindrome(number):
    print("Palindrome")
else:
    print("Not Palindrome")

