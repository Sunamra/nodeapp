#@ LCM of Two Numbers

def gcd(a, b):
    while b != 0:
        a, b = b, a % b
    return abs(a)

def gcd_recur(a, b):
    if b == 0:
        return abs(a)
    return gcd(b, a % b)


def lcm(p, q):
    return abs(p * q) // gcd(p, q)


x, y = int(input("Enter Number 1: ")), int(input("Enter Number 2: "))

print("LCM: ", lcm(x, y))