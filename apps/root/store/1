#@ Temperature Conversion
def cel_to_fah(temp):
    return (temp * (9 / 5)) + 32


temperature = int(input("Enter temperature in Celsius: "))
print(f"{temperature} Celsius is equivalent to {cel_to_fah(temperature)} Fahrenheit")

def fah_to_cel(temp):
    return (temp - 32) * (5 / 9)


temperature = int(input("Enter temperature in Celsius: "))
print(f"{temperature} Fahrenheit is equivalent to {fah_to_cel(temperature)} Celsius")
