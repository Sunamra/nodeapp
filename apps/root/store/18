#@ LCM of Multi Numbers

def gcd(a, b):
    while b != 0:
        a, b = b, a % b
    return abs(a)


def lcm(p, q):
    return abs(p * q) // gcd(p, q)


def lcm_multi(*args):
    if len(args) < 2:
        raise ValueError("At least two numbers are required")

    result = args[0]
    for num in args[1:]:
        result = lcm(result, num)

    return result


# Examples
print(lcm_multi(1, 2))        # 2
print(lcm_multi(1, 2, 3))     # 6
print(lcm_multi(4, 6, 8))     # 24