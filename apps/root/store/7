#@ Factorial


def factorial_iter(num):
    if num < 0:
        return None

    fact = 1

    for i in range(1, num + 1):
        fact = fact * i


def factorial_recur(num):
    if num < 0:
        return None

    if num == 0 or num == 1:
        return 1
    else:
        return num * factorial_recur(num - 1)


n = int(input("Enter a Number: "))

print("Factorial: ", factorial_iter(n))