#@ First n Fibonacci Series (Iteration)

def print_fib(n):
    x, y = 0, 1

    for _ in range(n):
        print(x, end=" ")
        x, y = y, x + y


def print_fib_recur(n, x=0, y=1):
    if n <= 0:
        return
    print(x, end=" ")
    print_fib_recur(n - 1, y, x + y)


print_fib(int(input("Enter Range: ")))
