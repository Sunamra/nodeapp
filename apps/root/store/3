#@ Leap year

def is_leap_year(year):
    if year % 400 == 0:
        return True
    if year % 100 == 0:
        return False
    if year % 4 == 0:
        return True
    else:
        return False


y = int(input("Enter a year: "))
if is_leap_year(y):
    print("Leap Year")
else:
    print("Not a Leap Year")
