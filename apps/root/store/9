#@ Check Armstrong

def length(num):
    count = 0
    temp = num

    while temp > 0:
        count += 1
        temp //= 10

    return count


def is_armstrong(num):
    temp = num
    digit_len = length(num)
    total = 0

    while temp > 0:
        rem = temp % 10
        total += rem**digit_len
        temp //= 10

    return total == num


n = int(input("Enter a Number: "))

if is_armstrong(n):
    print("Armstrong Number")
else:
    print("Not an Armstrong Number")
