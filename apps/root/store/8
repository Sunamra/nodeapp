#@ Check Prime

def isPrime(n):
    if n <= 1:
        return False
    else:
        for i in range(2, int(n**0.5) + 1):
            if n % i == 0:
                return False
    return True

for i in range(-99, 9999):
    if isPrime(i):
        print(i, end=" ")

num = int(input("Enter a number: "))

if isPrime(num):
    print("Prime")
else:
    print("Not Prime")

