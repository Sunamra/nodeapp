#@ Check Square Number

def is_square(num):
    if num >= 0:
        root = int(num**0.5)
    else:
        return None

    return root * root == num


n = int(input("Enter a number: "))

result = is_square(n)

if result is True:
    print("Square number")
elif result is None:
    print("Negative numbers are not square numbers")
else:
    print("Not a Square number")
