#@ e^x Series [x^i / i!]

def factorial(n):
    if n < 0:
        raise ValueError
    elif n == 0 or n == 1:
        return 1
    else:
        return n * factorial(n - 1)


def calc_series(x, n):
    total = 0

    for i in range(0, n):
        total += (x**i) / factorial(i)

    return total


x, n = int(input("Enter Value of x: ")), int(input("Enter Value of n: "))

print("Value of e^x: ", calc_series(x, n))
