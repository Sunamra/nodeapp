--PRINT EMPLOYEE AND PRODUCT DETAILS WHERE NAME STARTS WITH 'S’.
SELECT E.*, P.* FROM EMPLOYEE E, PRODUCT P WHERE E.S# = P.S# AND E.SNAME LIKE 'S%';

--PRINT PRODUCT DETAILS HAVING COMMON COLOR BUT DIFFERENT P#.
SELECT DISTINCT P1.* FROM PRODUCT P1, PRODUCT P2 WHERE P1.COLOR = P2.COLOR AND P1.P# <> P2.P#;

--PRINT EMPLOYEE AND PRODUCT DETAILS HAVING COMMON STATUS.
SELECT E.*, P.* FROM EMPLOYEE E, PRODUCT P WHERE E.S# = P.S# AND E.STATUS IN (SELECT STATUS FROM EMPLOYEE GROUP BY STATUS HAVING COUNT (*) > 1);

--PRINT PRODUCT DETAILS WHOSE WEIGHT IS GREATER THAN THE AVERAGE WEIGHT.
SELECT * FROM PRODUCT WHERE WEIGHT > (SELECT AVG (WEIGHT) FROM PRODUCT);

--PRINT THE ACCUMULATIVE WEIGHT OF THE PRODUCTS SOLD BY 'SMITH'.
SELECT SUM (P.WEIGHT) AS TOTAL_WEIGHT FROM EMPLOYEE E, PRODUCT P WHERE E.S# = P.S# AND E.SNAME = 'SMITH';

--PRINT THE NUMBER OF PRODUCTS SOLD BY EACH EMPLOYEE.
SELECT P.S#, E.SNAME, COUNT (P.P#) AS TOTAL_PRODUCTS FROM PRODUCT P, EMPLOYEE E WHERE E.S# = P.S# GROUP BY P.S#, E.SNAME;

--PRINT NUMBER OF COLOURS AND SID WHO HAVE SOLD MAXIMUM NUMBER OF DIFFERENT COLOURS OF PRODUCT.
SELECT S#, COUNT (DISTINCT COLOR) AS COLOR_COUNT FROM PRODUCT GROUP BY S# HAVING COUNT(DISTINCT COLOR) =
( SELECT MAX(COLOR_COUNT) FROM
( SELECT COUNT(DISTINCT COLOR) AS COLOR_COUNT FROM PRODUCT GROUP BY S# ));

SELECT S#, COUNT(DISTINCT COLOR) AS COLOR_COUNT
FROM PRODUCT
GROUP BY S#
HAVING COUNT(DISTINCT COLOR) = (
    SELECT MAX(COLOR_COUNT)
    FROM (
        SELECT COUNT(DISTINCT COLOR) AS COLOR_COUNT
        FROM PRODUCT
        GROUP BY S#
    ) color_counts  -- ← alias added here
);

