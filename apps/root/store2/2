--QUERIES TO CREATE THE TABLE
CREATE TABLE EMPLOYEE (S# VARCHAR2 (2) NOT NULL , SNAME VARCHAR2 (100) NOT NULL , STATUS NUMBER (5) NOT NULL , CITY VARCHAR2 (50) NOT NULL , PRIMARY KEY (S#)) ;
CREATE TABLE PRODUCT (P# VARCHAR2 (10),S# VARCHAR2 (10),PNAME VARCHAR2 (50),COLOR VARCHAR2 (20),WEIGHT INT,PRIMARY KEY (P#, S#), FOREIGN KEY (S#) REFERENCES EMPLOYEE (S#));

