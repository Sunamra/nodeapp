--CREATE A CURSOR TO INSERT DATA INTO TMARKS TABLE.
SET SERVEROUTPUT ON;
DECLARE
CURSOR C IS SELECT ROLLNO, SUM(MARKS) AS TOTAL FROM RESULT GROUP BY ROLLNO;
BEGIN
OPEN C;
FOR R IN C LOOP
INSERT INTO TMARKS (ROLLNO, TOTAL) VALUES (R.ROLLNO, R.TOTAL);
DBMS_OUTPUT.PUT_LINE('Inserted Rollno: ' || R.ROLLNO || ' Total: ' || R.TOTAL);
COMMIT ;
END LOOP;
CLOSE C;
END;
/

--CREATE A CURSOR FOR-LOOP TO PRINT ALL THE ROWS FROM RESULT TABLE WHERE MARKS > AVERAGE MARKS
SET SERVEROUTPUT ON;
DECLARE
CURSOR C IS SELECT * FROM RESULT WHERE MARKS > (SELECT AVG(MARKS) FROM RESULT);
BEGIN
OPEN C;
FOR R IN C LOOP
DBMS_OUTPUT.PUT_LINE('ROLLNO: ' || R.ROLLNO || ' MARKS: ' || R.MARKS);
END LOOP;
CLOSE C;
END;
/


--CREATE A CURSOR TO FETCH THE ROLLNO WITH MAXIMUM NUMBER OF ENTRY FROM RESULT TABLE. DELETE THE CORRESPONDING ROW FROM TMARKS TABLE
SET SERVEROUTPUT ON;
DECLARE
CURSOR C IS SELECT ROLLNO FROM RESULT GROUP BY ROLLNO HAVING COUNT(*) =
(SELECT MAX(CNT) FROM (SELECT COUNT(*) CNT FROM RESULT GROUP BY ROLLNO));
R RESULT.ROLLNO%TYPE;
BEGIN
OPEN C;
LOOP
FETCH C INTO R;
EXIT WHEN C%NOTFOUND;
DELETE FROM TMARKS WHERE ROLLNO = R;
DBMS_OUTPUT.PUT_LINE('Deleted ROLLNO: ' || R);
END LOOP;
COMMIT;
CLOSE C;
END;
/