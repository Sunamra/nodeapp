--CREATE PL/SQL BLOCK TO PRINT 1ST TWENTY ODD NUMBERS.
SET SERVEROUTPUT ON
DECLARE
C INT := 0;
NUM INT := 1;
BEGIN
WHILE C < 20 LOOP
DBMS_OUTPUT.PUT_LINE(NUM ||',');
NUM := NUM + 2;
C := C + 1;
END LOOP;
END;
/

--CREATE PL/SQL BLOCK TO PRINT THE FOLLOWING SERIES:
--1-2+3-4+5….N = RESULT [VALUE OF N SHOULD BE TAKEN FROM USER.]
SET SERVEROUTPUT ON
DECLARE
N INT := &N;
C INT := 1;
BEGIN
DBMS_OUTPUT.PUT(C);
FOR I IN 2..N LOOP
IF MOD (I,2) = 1 THEN
C := C+I;
DBMS_OUTPUT.PUT ('+' || I);
ELSE
C := C-I;
DBMS_OUTPUT.PUT ('-' || I);
END IF;
END LOOP;
DBMS_OUTPUT.PUT_LINE (' = ' || C);
END;
/

--CREATE PL/SQL BLOCK TO PRINT THE FOLLOWING SERIES:
--1
--1 2
--1 2 3
--FOR N NO. OF COLUMNS [VALUE OF N SHOULD BE TAKEN FROM USER.]
SET SERVEROUTPUT ON
DECLARE
N INT := &N;
BEGIN
FOR I IN 1..N LOOP
FOR J IN 1..I LOOP
DBMS_OUTPUT.PUT (J || ' ');
END LOOP;
DBMS_OUTPUT.PUT_LINE ('');
END LOOP;
END;
/

--CREATE PL/SQL BLOCK TO PRINT THE FOLLOWING SERIES:
--   1
--  1 1
-- 1 1 1
--FOR N NO. OF COLUMNS [VALUE OF N SHOULD BE TAKEN FROM USER.]
SET SERVEROUTPUT ON FORMAT WRAPPED
DECLARE
N INT := &N;
BEGIN
FOR I IN 1..N LOOP
FOR J IN 1..N-I LOOP
DBMS_OUTPUT.PUT (' ');
END LOOP;
FOR K IN 1..I LOOP
DBMS_OUTPUT.PUT ('1 ');
END LOOP;
DBMS_OUTPUT.PUT_LINE ('');
END LOOP;
END;
/

--CREATE PL/SQL BLOCK TO ACCEPT AN INTEGER VALUE AND CHECK WHETHER IT IS PALINDROME OR NOT.
SET SERVEROUTPUT ON
DECLARE
N INT := &N;
R INT := 0;
F INT ;
BEGIN
F := N;
WHILE N > 0 LOOP
R := R * 10 + MOD (N,10);
N := TRUNC (N / 10);
END LOOP;
IF F = R THEN
DBMS_OUTPUT.PUT_LINE ('PALINDROME NUMBER');
ELSE DBMS_OUTPUT.PUT_LINE ('NOT PALINDROME');
END IF ;
END;
/

--CREATE PL/SQL BLOCK TO ACCEPT A STRING VALUE AND CHECK WHETHER IT IS PALINDROME OR NOT.
SET SERVEROUTPUT ON
DECLARE
S VARCHAR (100) := '&S';
R VARCHAR (100);
BEGIN
S := LOWER(S);
FOR i IN REVERSE 1..LENGTH(S) LOOP
        R := R || SUBSTR(S, i, 1);
    END LOOP;
IF S = R THEN
DBMS_OUTPUT.PUT_LINE ('PALINDROME STRING');
ELSE
DBMS_OUTPUT.PUT_LINE ('NOT A PALINDROME STRING');
END IF ;
END;
/


--CREATE PL/SQL BLOCK TO ACCEPT A YEAR AND CHECK WHETHER IT IS LEAP YEAR OR NOT.

SET SERVEROUTPUT ON
DECLARE
    Y NUMBER := &Y;
BEGIN
    IF MOD(Y, 400) = 0 THEN
        DBMS_OUTPUT.PUT_LINE('LEAP YEAR');
        
    ELSIF MOD(Y, 100) = 0 THEN
        DBMS_OUTPUT.PUT_LINE('NOT A LEAP YEAR');
        
    ELSIF MOD(Y, 4) = 0 THEN
        DBMS_OUTPUT.PUT_LINE('LEAP YEAR');
        
    ELSE
        DBMS_OUTPUT.PUT_LINE('NOT A LEAP YEAR');
    END IF;
END;
/


